{
  "manifest_version": 2,
  "name": "WebExtension native messaging",
  "version": "1.4.3",

  "description": "Personal multi-purpose WebExtension interacting with native application.",
  "author": "Julien Coloos",
  "homepage_url": "https://github.com/suiryc/webextensions",

  // We delegate many actions to a native application:
  //  - TiddlyWiki saving
  //  - resource (file) downloading
  // For this we need the nativeMessaging permission.
  // Many features use configurable settings, which need the storage permission.
  // For tab successor handling, we use:
  //  - tabs: to get/change tab properties
  // For links catching, we use:
  //  - clipboardWrite: to write links to clipboard
  // For downloads, we use:
  //  - contextMenus: add entry to download given link
  //  - cookies: to get cookies for given URL
  //  - downloads: to intercept and access created downloads
  //  - history: to remove downloads from history
  //  - notifications: to notify when a request/download/link was intercepted
  //  - tabs: to get a tab properties (title used as DL comment)
  //  - webNavigation: to work with frames (dynamic script execution)
  //  - webRequest/webRequestBlocking: to intercept requests
  //  - <all_urls>: so that webRequest and cookies work for all URLs
  // For TiddlyWiki we use:
  //  - tabs: to get tabs properties (url is the local file to save to)
  //  - webNavigation: to work with frames (dynamic script execution)
  "permissions": [
    "clipboardWrite",
    "contextMenus",
    "cookies",
    "downloads",
    "history",
    "nativeMessaging",
    "notifications",
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],

  // We need to allow 'Function' usage
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self';",

  "icons": {
    "48": "/resources/icon.svg",
    "96": "/resources/icon.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      // Our id, to communicate with a native application
      "id": "__EXTENSION_ID__",
      // Data collection
      "data_collection_permissions": {
        // Technically, data are collected and used for what was asked to do in
        // the browser, which primarily is:
        //  - download files
        //  - download HLS (video) and subtitles
        //  - copy links in the clipboard
        // No data is transmitted to any third-party.
        "required": [
          // browsingActivity: URLs of fetched resources can be used for refined
          // treatment through the extension (details in "websiteContent").
          "browsingActivity",
          // websiteContent: we intercept requests/responses in order to determine
          // whether there are refined treatments to do through the extension.
          // When dealing with files (actual downloads), downloading is delegated
          // to an external dedicated download application, with better handling
          // than the browser internal one.
          // When dealing with HLS (video) and subtitles, we get the text content
          // by re-doing the same requests than the browser (cookies included),
          // either in the extension or the associated native application.
          // Download of underlying video segments is also delegated to an
          // external dedicated download application.
          // We also add context menu entries to manually download some links
          // that match the extension criteria.
          // User can also visually select a zone in the page, collect links
          // found inside the zone, and copy these links in the clipboard.
          "websiteContent",
          // websiteActivity: the main purpose of the extension is to intercept
          // downloads and delegate them to an external application instead of
          // relying on the (too simple and limited) browser download feature.
          "websiteActivity"
        ]
      },
      // Personal site with versions and update manifest
      "update_url": "https://files.suiryc-139.freeddns.org/webext/__EXTENSION_SLUG__-update.json"
    }
  },

  "background": {
    "scripts": [ "/dist/background.bundle.js" ]
  },

  "content_scripts": [{
    "matches": ["<all_urls>"],
    "all_frames": true,
    "js": ["/dist/content-script.bundle.js"],
    "run_at": "document_start"
  }],

  "browser_action": {
    "default_icon": "/resources/icon.svg",
    "default_popup": "/resources/browser-action.html"
  },

  "options_ui": {
    "page": "/resources/options-ui.html",
    "open_in_tab": true
  }
}
